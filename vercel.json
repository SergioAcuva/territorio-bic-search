{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/lote.js": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}
